{
	"backlight": {
		"format": "{icon} {percent}%",
		"format-icons": [
			"юОН", "юПУ", "юПС", "юПП", "юПО", "юПН", "юПК", "юПИ", "юОЫ"
		],
		"max-length": 7,
		"min-length": 7,
		"on-scroll-up": "~/.config/waybar/scripts/backlight up",
		"on-scroll-down": "~/.config/waybar/scripts/backlight down",
		"tooltip-format": "Screen Brightness"
	}
}
